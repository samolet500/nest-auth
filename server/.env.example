COMPOSE_PROJECT_NAME=nest-auth

NODE_ENV='development'

APPLICATION_PORT=4000
# Публичный URL бэкенда для OAuth redirect_uri. ${APPLICATION_PORT} подставляется в коде (см. providers.config.ts): обычный .env не делает вложенную подстановку.
APPLICATION_URL=http://localhost:${APPLICATION_PORT}
ALLOWED_ORIGIN='http://localhost:3000'

POSTGRES_USER='root'
POSTGRES_PASSWORD='123456'
POSTGRES_HOST='localhost'
POSTGRES_PORT=5433
POSTGRES_DB='full-authorization'
# Optional: full URL for Prisma (must be literal — .env does not expand ${...}).
# Otherwise prisma.config.ts builds the URL from POSTGRES_* above.
# POSTGRES_URL=postgresql://root:123456@localhost:5433/full-authorization

REDIS_USER='default'
REDIS_PASSWORD='pass123456'
REDIS_HOST='localhost'
REDIS_PORT=6379
REDIS_URI='redis://${REDIS_USER}:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}'

GOOGLE_RECAPTCHA_SECRET_KEY='some_secret_key'

GOOGLE_CLIENT_ID='some_client_id'
GOOGLE_CLIENT_SECRET='some_client_secret'

YANDEX_CLIENT_ID='some_client_id'
YANDEX_CLIENT_SECRET='some_client_secret'